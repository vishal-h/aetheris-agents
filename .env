# Aetheris model/provider defaults
# Sourced by aetheris/scripts/sprint.sh and read by agent .exs files via
# Application.get_env(:aetheris, :default_model).
#
# Copy to .env.local and override values there for local experiments.
# .env.local is gitignored; .env is committed.

AETHERIS_MODEL=claude-haiku-4-5-20251001
AETHERIS_PROVIDER=anthropic

# Per-use-case overrides — uncomment and set to override for a specific use case.
# Unset means fall back to AETHERIS_MODEL / AETHERIS_PROVIDER.

# PROVENANCE_MODEL=claude-haiku-4-5-20251001
# PAYSLIP_MODEL=claude-haiku-4-5-20251001
# EMAIL_MODEL=claude-haiku-4-5-20251001
# DRIVE_MODEL=claude-haiku-4-5-20251001
# API_MODEL=claude-haiku-4-5-20251001
