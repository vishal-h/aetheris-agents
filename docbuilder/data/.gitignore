# Real client data — never commit; only anonymised sample fixtures are committed
*.csv
!sample_data.csv
!sample_data_summary.csv

# Per-run history (m3 context builder "same as last month") — accumulates client
# context (names, emails, addresses); seeded locally, never committed
run_log.json

# Real client templates — never commit; demo/ tenant is committed in full
templates/*/
!templates/demo/

# Demo base files (branding) — committed alongside the JSON config (m2a)
!templates/demo/proposal_v1.xlsx
!templates/demo/proposal_v1.docx

# Demo narrative-mode template files (m2a)
!templates/demo/proposal_v1.md.template
!templates/demo/proposal_v1.css

# Demo template catalogue (m2a)
!templates/demo/catalogue.json

# Bitloka tenant invoice bundle (m2b) — narrative-mode, no base files
!templates/bitloka/
!templates/bitloka/catalogue.json
!templates/bitloka/invoice/
!templates/bitloka/invoice/v1/
!templates/bitloka/invoice/v1/**
